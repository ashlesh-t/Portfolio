{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/adminmode/layout,_N_T_/adminmode/page,_N_T_/adminmode"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/adminmode/__PAGE__",
    "/adminmode",
    "/_index",
    "/_head"
  ]
}